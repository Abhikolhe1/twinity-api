// Prisma Schema for Twinity API
// Migrated from Mongoose/MongoDB to Prisma/PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum UserAccountType {
  individual
  influencer
  agency
}

enum UserAuthProvider {
  email
  google
}

enum UserStatus {
  active
  blocked
  pending
}

enum VideoJobProductType {
  greeting
  video_ad   @map("video-ad")
  image_ad   @map("image-ad")
}

enum VideoJobStatus {
  pending
  in_progress @map("in-progress")
  review
  delivered
  failed
  cancelled
}

enum LeadStatus {
  new
  contacted
  negotiating
  paid
  closed
  lost
}

enum LeadSource {
  book_call    @map("book-call")
  contact_form @map("contact-form")
  direct
}

enum AdminRole {
  super_admin @map("super-admin")
  admin
  ops
}

enum OtpType {
  email_verification
  login_mfa
  mfa_setup
  password_reset_otp
}

enum CelebrityOnboardingStatus {
  pending_review
  approved
  rejected
}

// ── Models ─────────────────────────────────────────────────────────────────────

model User {
  id                       String           @id @default(uuid())
  name                     String
  email                    String           @unique
  password                 String
  phone                    String?
  company                  String?
  avatar_url               String?
  account_type             UserAccountType  @default(individual)
  auth_provider            UserAuthProvider @default(email)
  has_email_password       Boolean          @default(false)
  is_email_verified        Boolean          @default(false)
  email_verification_token String?
  password_reset_token     String?
  password_reset_expires   DateTime?
  status                   UserStatus       @default(pending)
  last_login_at            DateTime?
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  suspension_reason     String?
  suspended_at          DateTime?
  suspended_by_admin_id String?

  video_jobs VideoJob[]
  leads      Lead[]
  otp_codes  OtpCode[]

  @@index([status])
  @@map("users")
}

model Celebrity {
  id                  String                     @id @default(uuid())
  name                String
  name_ar             String
  legal_name          String?
  slug                String                     @unique
  industry            String
  nationality         String
  nationality_ar      String
  region              String?
  contact_email       String?
  contact_phone       String?
  languages           String[]
  tags                String[]
  tags_ar             String[]
  bio                 String?
  bio_ar              String?
  social_links        Json                       @default("{}")
  allowed_content_categories String[]            @default([])
  prohibited_industries     String[]            @default([])
  competitor_brands         String[]            @default([])
  geographic_availability   Json                @default("{\"mode\":\"global\",\"allowedRegions\":[],\"restrictedRegions\":[]}")
  tone_style_preferences    Json                @default("{\"communicationStyle\":\"\",\"visualStyle\":\"\",\"endorsedTopics\":[],\"personalRestrictions\":[]}")
  approval_preferences      Json                @default("{\"greetingAutoApprove\":false,\"manualReviewRequired\":true,\"slaHours\":48,\"fastTrackEligible\":false,\"templatePolicyReviewed\":false}")
  preapproved_template_ids  String[]            @default([])
  manager_settings          Json                @default("{\"selfManaged\":true,\"agencyName\":\"\",\"managerName\":\"\",\"managerEmail\":\"\",\"managerPhone\":\"\",\"permissions\":[]}")
  approved_media_urls       String[]            @default([])
  contract_acceptance       Json                @default("{\"accepted\":false,\"acceptedAt\":null,\"signedName\":\"\"}")
  avatar_color        String                     @default("linear-gradient(135deg, #9a78fe, #422266)")
  initials            String
  thumbnail_url       String?
  voice_model_id      String?
  training_audio_url  String?
  is_active           Boolean                    @default(true)
  is_featured         Boolean                    @default(false)
  onboarding_status   CelebrityOnboardingStatus  @default(approved)
  applied_at          DateTime                   @default(now())
  reviewed_at         DateTime?
  review_notes        String?
  reviewed_by_admin_id String?
  price_range         Json                       @default("{\"greeting\":{\"min\":500,\"max\":2000},\"video-ad\":{\"min\":2000,\"max\":8000}}")
  total_orders        Int                        @default(0)
  created_at          DateTime                   @default(now())
  updated_at          DateTime                   @updatedAt

  reviewed_by    Admin?                 @relation("CelebrityReviewedBy", fields: [reviewed_by_admin_id], references: [id])
  portal_admin   Admin?                 @relation("CelebrityPortalAccount")
  video_jobs     VideoJob[]
  manager_links  CelebrityManagerLink[]

  @@index([industry, is_active])
  @@index([onboarding_status])
  @@index([is_active, onboarding_status])
  @@map("celebrities")
}

model VideoJob {
  id                    String              @id @default(uuid())
  reference_id          String              @unique
  user_id               String
  celebrity_id          String
  product_type          VideoJobProductType
  purpose               String
  template_id           String?
  approval_path         String?
  script                String
  tone                  String?
  duration              String              @default("30s")
  aspect_ratio          String              @default("16:9")
  resolution            String              @default("1080p")
  channels              String[]
  status                VideoJobStatus      @default(pending)
  status_history        Json                @default("[]")
  submission_context    Json                @default("{}")
  validation_result     Json                @default("{}")
  submission_audit      Json                @default("[]")
  business_verification_required Boolean    @default(false)
  business_verification_passed   Boolean    @default(true)
  estimated_price       Float
  currency              String              @default("USD")
  download_enabled      Boolean             @default(false)
  preview_url           String?
  final_video_url       String?
  watermarked_url       String?
  creatify_job_id       String?
  voice_job_id          String?
  voice_audio_url       String?
  voice_model           String?
  voice_speed           Float?
  voice_change_enabled  Boolean             @default(false)
  voice_change_source_url String?
  prop_images           String[]
  scene_notes           String?
  background_image_url  String?
  audio_duration        Float?
  processed_script      String?
  error_message         String?
  delivered_at          DateTime?
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt

  user      User      @relation(fields: [user_id], references: [id])
  celebrity Celebrity @relation(fields: [celebrity_id], references: [id])
  leads     Lead[]

  @@index([user_id, status])
  @@index([status])
  @@index([creatify_job_id])
  @@map("video_jobs")
}

model Lead {
  id              String     @id @default(uuid())
  user_id         String?
  video_job_id    String?
  name            String
  email           String
  phone           String?
  company         String?
  celebrity_name  String
  product_type    String
  purpose         String
  notes           String?
  estimated_value Float      @default(0)
  currency        String     @default("USD")
  status          LeadStatus @default(new)
  status_history  Json       @default("[]")
  assigned_to     String?
  follow_up_date  DateTime?
  source          LeadSource @default(book_call)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  user      User?     @relation(fields: [user_id], references: [id])
  video_job VideoJob? @relation(fields: [video_job_id], references: [id])

  @@index([status])
  @@index([email])
  @@map("leads")
}

model Admin {
  id                     String    @id @default(uuid())
  name                   String
  email                  String    @unique
  password               String
  role                   AdminRole @default(ops)
  role_id                String?
  celebrity_id           String?   @unique
  is_active              Boolean   @default(true)
  must_change_password   Boolean   @default(false)
  profile_completed      Boolean   @default(true)
  last_login_at          DateTime?
  password_reset_token   String?
  password_reset_expires DateTime?
  mfa_enabled            Boolean   @default(false)
  mfa_secret             String?
  mfa_backup_codes       String[]  @default([])
  login_attempts         Int       @default(0)
  locked_until           DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  assigned_role                   Role?                  @relation("AdminRole", fields: [role_id], references: [id])
  created_roles                   Role[]                 @relation("RoleCreatedBy")
  celebrity                       Celebrity?             @relation("CelebrityPortalAccount", fields: [celebrity_id], references: [id])
  reviewed_celebrity_applications Celebrity[]            @relation("CelebrityReviewedBy")
  manager_links                   CelebrityManagerLink[] @relation("AdminManagerLinks")

  @@map("admins")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  permissions String[]
  is_system   Boolean  @default(false)
  created_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  admins  Admin[] @relation("AdminRole")
  creator Admin?  @relation("RoleCreatedBy", fields: [created_by], references: [id])

  @@map("roles")
}

model Template {
  id              String   @id @default(uuid())
  name            String
  name_ar         String
  description     String
  description_ar  String
  purpose         String
  purpose_ar      String
  sample_script   String
  sample_script_ar String
  product_types   String[]
  duration        String   @default("30s")
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([product_types])
  @@index([is_active])
  @@index([purpose])
  @@map("templates")
}

model ProductType {
  id                  String   @id @default(uuid())
  slug                String   @unique
  name                String
  name_ar             String
  description         String
  description_ar      String
  detail              String
  detail_ar           String
  icon                String   @default("")
  price_from          Float    @default(0)
  duration            String   @default("")
  duration_ar         String   @default("")
  use_cases           String[]
  use_cases_ar        String[]
  video_prompt        String   @default("")
  gemini_system_prompt String  @default("")
  is_active           Boolean  @default(true)
  order               Int      @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([is_active, order])
  @@map("product_types")
}

model Setting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String   @default("")
  type       String   @default("general")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("settings")
}

model BlockedWord {
  id         String   @id @default(uuid())
  word       String   @unique
  created_at DateTime @default(now())

  @@map("blocked_words")
}

model AuditLog {
  id          String   @id @default(uuid())
  actor_id    String
  actor_name  String
  actor_role  String
  action      String
  target_type String
  target_id   String
  target_name String?
  reason      String?
  metadata    Json     @default("{}")
  created_at  DateTime @default(now())

  @@index([actor_id])
  @@index([target_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_logs")
}

model OtpCode {
  id         String   @id @default(uuid())
  email      String
  code       String
  type       OtpType
  expires_at DateTime
  used       Boolean  @default(false)
  attempts   Int      @default(0)
  user_id    String?
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([email, type])
  @@index([expires_at])
  @@map("otp_codes")
}

model CelebrityManagerLink {
  id           String   @id @default(uuid())
  celebrity_id String
  admin_id     String
  permissions  String[] @default([])
  is_active    Boolean  @default(true)
  linked_by    String?
  notes        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  celebrity Celebrity @relation(fields: [celebrity_id], references: [id])
  admin     Admin     @relation("AdminManagerLinks", fields: [admin_id], references: [id])

  @@unique([celebrity_id, admin_id])
  @@index([celebrity_id])
  @@index([admin_id])
  @@map("celebrity_manager_links")
}
