# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://twinity:password@localhost:5432/db_twinity

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Admin JWT (separate secret)
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# AWS SES (Email)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
SES_FROM_EMAIL=no-reply@twinity.ai
ADMIN_EMAIL=admin@twinity.ai

# AWS S3
S3_BUCKET_VIDEOS=twinity-videos
S3_BUCKET_ASSETS=twinity-assets

# Redis (ElastiCache)
REDIS_URL=redis://localhost:6379

# ElevenLabs (TTS + Voice Cloning)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Higgsfield (Talking Photo lip-sync video generation)
HIGGSFIELD_API_KEY=your_higgsfield_key

# Customer App URL (CORS)
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
